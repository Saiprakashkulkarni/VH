# ── VotePath AI Server — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5002

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Connection string for your MongoDB Atlas cluster or local instance
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT Authentication ────────────────────────────────────────────────────────
# Strong random secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── Mistral AI ────────────────────────────────────────────────────────────────
# API key from https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Google Cloud Services ─────────────────────────────────────────────────────
# Path to your Google Cloud service account JSON key file
# Required for: Cloud Natural Language API, Cloud Translation API
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Base64-encoded Firebase service account JSON (for Google Sign-In verification)
# Generate with: base64 -i serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (in addition to defaults)
# ALLOWED_ORIGINS=https://your-custom-domain.com
